# Web Scraper 示例配置
# 复制此文件为 .env 并修改

# ===== 超时配置 =====
# 连接超时（秒）
WEB_SCRAPER_CONNECT_TIMEOUT=10

# 读取超时（秒）
WEB_SCRAPER_READ_TIMEOUT=30

# 总超时（秒）
WEB_SCRAPER_TOTAL_TIMEOUT=60

# ===== 重试配置 =====
# 最大重试次数
WEB_SCRAPER_MAX_RETRIES=3

# 重试延迟（秒）
WEB_SCRAPER_RETRY_DELAY=1.0

# 重试退避系数
# WEB_SCRAPER_RETRY_BACKOFF=2.0

# ===== 连接池配置 =====
# 最大连接数
WEB_SCRAPER_MAX_CONNECTIONS=100

# 每个主机最大连接数
# WEB_SCRAPER_MAX_CONNECTIONS_PER_HOST=10

# ===== 请求配置 =====
# User-Agent
# WEB_SCRAPER_USER_AGENT=Mozilla/5.0 (compatible; WebScraper/1.0)

# 是否跟随重定向
# WEB_SCRAPER_FOLLOW_REDIRECTS=true

# 最大重定向次数
# WEB_SCRAPER_MAX_REDIRECTS=10

# ===== 代理配置 =====
# HTTP/HTTPS 代理
# WEB_SCRAPER_PROXY=http://proxy.example.com:8080

# 代理认证（用户名:密码）
# WEB_SCRAPER_PROXY_AUTH=username:password

# ===== 速率限制 =====
# 每秒最大请求数
WEB_SCRAPER_REQUESTS_PER_SECOND=2.0

# 突发请求大小
# WEB_SCRAPER_BURST_SIZE=5

# ===== 内容限制 =====
# 最大内容长度（字节）
WEB_SCRAPER_MAX_CONTENT_LENGTH=10485760

# 最大文本长度（字符）
# WEB_SCRAPER_MAX_TEXT_LENGTH=10000
